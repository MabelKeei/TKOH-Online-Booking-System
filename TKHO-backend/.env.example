PORT=3210
NODE_ENV=development

DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/tkho_booking?schema=public"

REDIS_URL=redis://127.0.0.1:6379

# P1: EV 日历余量 Redis 缓存 TTL（秒）；预订成功后版本号 +1 使旧缓存失效
EV_CALENDAR_CACHE_TTL_SEC=10
# P1.5: assignment-preview 空闲车位列表缓存 TTL（秒）；与日历共用 ver 失效
EV_ASSIGNMENT_PREVIEW_CACHE_TTL_SEC=8
# P1: EV booking window 缓存 TTL（秒）；Admin 发布时主动失效
EV_BOOKING_WINDOW_CACHE_TTL_SEC=60
# P1: 每用户每分钟最多几次 POST /api/parking/bookings（Redis 不可用时不限流）
EV_BOOKING_RATE_LIMIT_PER_MIN=30

JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# 超过 N 个月未登录（或从未登录且账号创建超过 N 个月）的 Active 用户自动设为 Inactive
# Admin System Settings 中的数据库配置优先；仅在数据库无有效值时使用此环境变量
USER_INACTIVE_AFTER_MONTHS=6
