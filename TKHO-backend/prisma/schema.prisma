generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               BigInt        @id
  corpId           String        @unique @map("corp_id")
  account          String        @unique
  password         String
  name             String
  accessRoleId     BigInt?       @map("access_role_id")
  departmentId     BigInt?       @map("department_id")
  email            String?
  contact          String?
  annualQuotaEv    Int?          @default(0) @map("annual_quota_ev")
  usedQuotaEv      Int?          @default(0) @map("used_quota_ev")
  annualQuotaVenue Int?          @default(0) @map("annual_quota_venue")
  usedQuotaVenue   Int?          @default(0) @map("used_quota_venue")
  status           String        @default("Active")
  lastLoginTime    DateTime?     @map("last_login_time") @db.Timestamptz(6)
  createdAt        DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  access_roles            access_roles?   @relation(fields: [accessRoleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  department              departments?    @relation(fields: [departmentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  pending_users           pending_users[]
  venueBookingsReserved VenueBookings[] @relation("VenueBookingReservedBy")
  venueBookingsHandled  VenueBookings[] @relation("VenueBookingHandler")

  @@map("user")
}

model Venues {
  id                   BigInt                 @id
  name                 String                 @unique
  nameZh               String?                @map("name_zh")
  tab                  String?
  venueType            String?                @map("venue_type")
  color                String?
  location             String?
  locationZh           String?                @map("location_zh")
  displayType          String?                @map("display_type")
  imageUrl             String?                @map("image_url")
  status               String                 @default("active")
  createdAt            DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  roomCapacity         Int?                   @map("room_capacity")
  display_venue_rules  display_venue_rules?
  venueBookings VenueBookings[]
  venue_blocks  venue_blocks[]

  @@map("venues")
}

model EvParkingSlots {
  id        BigInt       @id
  evSpace   String       @map("ev_space")
  location  String?
  status    String       @default("active")
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  bookings  EvBookings[]

  @@map("ev_parking_slots")
}

model EvTimePeriods {
  id        BigInt       @id
  period    String       @unique
  startTime DateTime     @map("start_time") @db.Time(6)
  endTime   DateTime     @map("end_time") @db.Time(6)
  status    String       @default("active")
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  bookings  EvBookings[]

  @@map("ev_time_periods")
}

model EvBookings {
  id             BigInt         @id @default(autoincrement())
  userCorpId     String?        @map("user_corp_id")
  licensePlateId BigInt         @map("license_plate_id")
  slotId         BigInt         @map("slot_id")
  periodId       BigInt?        @map("period_id")
  bookingDate    DateTime       @map("booking_date") @db.Date
  bookedOn       DateTime?      @map("booked_on") @db.Timestamptz(6)
  status         String
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  licensePlate   license_plates @relation(fields: [licensePlateId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  period         EvTimePeriods? @relation(fields: [periodId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  slot           EvParkingSlots @relation(fields: [slotId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([slotId, periodId, bookingDate], map: "idx_ev_bookings_slot_period_date")
  @@map("ev_bookings")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model access_roles {
  id                 BigInt   @id
  role_name          String
  description        String?
  annual_venue_quota Int?     @default(0)
  annual_ev_quota    Int?     @default(0)
  employee_count     Int?     @default(0)
  created_at         DateTime @default(now()) @db.Timestamptz(6)
  users              User[]
  pending_users      pending_users[]
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model account_vehicles {
  id         BigInt   @id @default(autoincrement())
  plate      String   @unique
  is_default Boolean  @default(false)
  created_at DateTime @default(now()) @db.Timestamptz(6)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model booking_window_history {
  id            BigInt    @id
  resource_type String
  start_date    DateTime  @db.Date
  end_date      DateTime  @db.Date
  published_at  DateTime? @db.Timestamptz(6)
  published_by  String?
  created_at    DateTime  @default(now()) @db.Timestamptz(6)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model booking_windows {
  resource_type      String    @id
  current_start_date DateTime  @db.Date
  current_end_date   DateTime  @db.Date
  updated_by         String?
  updated_at         DateTime? @db.Timestamptz(6)
  created_at         DateTime  @default(now()) @db.Timestamptz(6)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model departments {
  id              BigInt   @id
  department_name String   @unique
  description     String?
  employee_count  Int?     @default(0)
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  users           User[]
  pending_users   pending_users[]
}

model display_config_settings {
  config_key   String    @id
  config_value String?
  updated_at   DateTime? @default(now()) @db.Timestamptz(6)
}

model display_venue_rules {
  id              BigInt @id @default(autoincrement())
  venue_id        BigInt @unique
  merge_group     String?
  display_name    String?
  arrow_direction String?
  venues          Venues @relation(fields: [venue_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model license_plates {
  id           BigInt       @id
  user_id      BigInt?      @map("user_id")
  plate_number String       @unique
  is_default   Boolean      @default(false)
  status       String       @default("active")
  created_at   DateTime     @default(now()) @db.Timestamptz(6)
  ev_bookings  EvBookings[]
}

/// 场地预订主表：统一承载日历视图、我的预订、管理审批等场景。
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model VenueBookings {
  /// 主键，自增。
  id             BigInt    @id @default(autoincrement())
  /// 场地 ID，关联 venues.id。
  venueId        BigInt?   @map("venue_id")
  /// 预订人/预留人用户 ID，关联 user.id（联系信息从 user 读取）。
  reservedByUserId BigInt? @map("reserved_by")
  /// 会议/活动主题。
  meetingTitle   String?   @map("meeting_title")
  /// 预订日期。
  bookingDate    DateTime? @map("booking_date") @db.Date
  /// 开始时间，供日历格展示与时段冲突校验。
  startTime      DateTime? @map("start_time") @db.Time(6)
  /// 结束时间，供日历格展示与时段冲突校验。
  endTime        DateTime? @map("end_time") @db.Time(6)
  /// 预计参会人数。
  attendees      Int?
  /// 预订备注。
  notes          String?
  /// 预订生命周期状态：如 upcoming、past、canceled。
  status         String?
  /// 预订类型，默认 venue（场地预订）。
  bookingType    String?   @default("venue") @map("booking_type")
  /// 审批状态：pending、approved、rejected。
  approvalStatus String?   @map("approval_status")
  /// 审批处理人用户 ID（通过或拒绝），关联 user.id。
  handleByUserId BigInt?   @map("handle_by")
  /// 审批处理时间（通过或拒绝）。
  handledAt      DateTime? @map("handled_at") @db.Timestamptz(6)
  /// 拒绝原因（仅 rejected 时有值）。
  rejectReason   String?   @map("reject_reason")
  /// 预订时是否勾选需要茶水服务；详情见 venue_tea_service.tea_service。
  teaServiceRequired Boolean @default(false) @map("tea_service_required")
  /// 用户提交预订的时间。
  submittedAt    DateTime? @map("submitted_at") @db.Timestamptz(6)
  /// 记录创建时间。
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  /// 记录最后修改时间；业务更新时应同步刷新。
  updatedAt      DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  venue             Venues?               @relation(fields: [venueId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  reservedBy        User?                 @relation("VenueBookingReservedBy", fields: [reservedByUserId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  handler           User?                 @relation("VenueBookingHandler", fields: [handleByUserId], references: [id], onDelete: SetNull, onUpdate: NoAction)
  venueTeaService   VenueTeaService?

  @@index([venueId, bookingDate], map: "idx_venue_bookings_venue_date")
  @@index([approvalStatus], map: "idx_venue_bookings_approval_status")
  @@map("venue_bookings")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model pending_users {
  id               BigInt        @id
  corp_id          String
  name             String
  department_id    BigInt?
  access_role_id   BigInt?
  approver_user_id BigInt?
  approver_name    String?
  email            String?
  contact_no       String?
  reason           String?
  reject_reason    String?
  submitted_at     DateTime?     @db.Timestamptz(6)
  handled_at       DateTime?     @db.Timestamptz(6)
  approval_status  String        @default("Pending")
  created_at       DateTime      @default(now()) @db.Timestamptz(6)
  departments      departments?  @relation(fields: [department_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  access_roles     access_roles? @relation(fields: [access_role_id], references: [id], onDelete: NoAction, onUpdate: NoAction)
  approver         User?         @relation(fields: [approver_user_id], references: [id], onDelete: SetNull, onUpdate: NoAction)
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model prompts {
  id            BigInt   @id
  prompt_key    String
  name          String
  content       String
  category      String
  can_add       Boolean  @default(false)
  template_type String?
  created_at    DateTime @default(now()) @db.Timestamptz(6)
}

/// 场地预订茶水服务：一对一关联 venue_bookings；茶歇详情以本表 tea_service 为准。
/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model VenueTeaService {
  /// 关联 venue_bookings.id（主键即外键，有茶歇才存在此行）
  venueBookingId BigInt        @id @map("venue_booking_id")
  /// 茶歇需求 JSON（饮品、供应方式、人数、备注等）；展示板读本字段。
  teaService     Json          @map("tea_service")
  /// 茶水间是否已在展示板标记完成。
  completed      Boolean       @default(false)
  /// 进入茶水展示板队列的时间（可与预订 submitted_at 不同）。
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz(6)
  venueBooking   VenueBookings @relation(fields: [venueBookingId], references: [id], onDelete: Cascade, onUpdate: NoAction)

  @@index([completed], map: "idx_venue_tea_service_completed")
  @@map("venue_tea_service")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model venue_blocks {
  id         BigInt   @id
  venue_id   BigInt
  start_at   DateTime @db.Timestamptz(6)
  end_at     DateTime @db.Timestamptz(6)
  reason     String?
  created_at DateTime @default(now()) @db.Timestamptz(6)
  venues     Venues   @relation(fields: [venue_id], references: [id], onDelete: Cascade, onUpdate: NoAction)
}

