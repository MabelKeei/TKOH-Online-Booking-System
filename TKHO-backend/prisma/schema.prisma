generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id               BigInt    @id
  corpId           String    @unique @map("corp_id")
  account          String    @unique
  password         String
  name             String
  department       String?
  role             String?
  position         String?
  email            String?
  contact          String?
  annualQuotaEv    Int?      @default(0) @map("annual_quota_ev")
  usedQuotaEv      Int?      @default(0) @map("used_quota_ev")
  annualQuotaVenue Int?      @default(0) @map("annual_quota_venue")
  usedQuotaVenue   Int?      @default(0) @map("used_quota_venue")
  status           String    @default("Active")
  lastLoginTime    DateTime? @map("last_login_time") @db.Timestamptz(6)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("user")
}

model Venues {
  id                   BigInt                 @id
  name                 String                 @unique
  nameZh               String?                @map("name_zh")
  tab                  String?
  venueType            String?                @map("venue_type")
  color                String?
  location             String?
  locationZh           String?                @map("location_zh")
  displayType          String?                @map("display_type")
  imageUrl             String?                @map("image_url")
  status               String                 @default("active")
  createdAt            DateTime               @default(now()) @map("created_at") @db.Timestamptz(6)
  roomCapacity         Int?                   @map("room_capacity")
  display_venue_rules  display_venue_rules[]
  meeting_bookings     meeting_bookings[]
  tea_service_requests tea_service_requests[]
  venue_blocks         venue_blocks[]

  @@map("venues")
}

model EvParkingSlots {
  id         BigInt       @id
  slotNumber String       @map("slot_number")
  location   String?
  space      String
  quantity   Int          @default(1)
  slotType   String       @default("EV") @map("slot_type")
  status     String       @default("active")
  createdAt  DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  bookings   EvBookings[]

  @@map("ev_parking_slots")
}

model EvTimePeriods {
  id        BigInt       @id
  period    String       @unique
  startTime DateTime     @map("start_time") @db.Time(6)
  endTime   DateTime     @map("end_time") @db.Time(6)
  status    String       @default("active")
  createdAt DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  bookings  EvBookings[]

  @@map("ev_time_periods")
}

model EvBookings {
  id             BigInt         @id @default(autoincrement())
  sourceId       BigInt?        @map("source_id")
  employeeCorpId String?        @map("employee_corp_id")
  plateNumber    String         @map("plate_number")
  slotId         BigInt         @map("slot_id")
  periodId       BigInt?        @map("period_id")
  bookingDate    DateTime       @map("booking_date") @db.Date
  bookedOn       DateTime?      @map("booked_on") @db.Timestamptz(6)
  status         String
  reason         String?
  sourceRawTime  String?        @map("source_raw_time")
  sourceRawSpace String?        @map("source_raw_space")
  createdAt      DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)
  period         EvTimePeriods? @relation(fields: [periodId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  slot           EvParkingSlots @relation(fields: [slotId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([slotId, periodId, bookingDate], map: "idx_ev_bookings_slot_period_date")
  @@map("ev_bookings")
}

